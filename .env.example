# Copy this file to `.env` and fill in the values below.
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.

# Postgres connection (matches the local Docker setup in docker-compose.yml).
# Leave as-is unless you point at a different database.
DATABASE_URL="postgresql://aem:aem_dev@localhost:5433/aem?schema=public"

# Auth.js session secret. Generate a real value with:
#   openssl rand -base64 32
AUTH_SECRET="generate-me-with-openssl-rand-base64-32"

# Google Gemini API key (algorithmic/AI features — Phase 4+). Optional until then.
GEMINI_API_KEY=""
